---
interface Props {
  src: string
  caption?: string
  autoplay?: boolean
  controls?: boolean
  loop?: boolean
}

const { src, caption = "", autoplay = false, controls = true, loop = false } = Astro.props

// Generate a unique ID for the audio element
const audioId = `audio-${Math.random().toString(36).substr(2, 9)}`
---

<div class="audio-player">
  <audio id={audioId} src={src} controls={controls} autoplay={autoplay} loop={loop} preload="metadata">
    <p>
      Your browser does not support the audio element.
      <a href={src}>Download the audio file</a>.
    </p>
  </audio>
  {caption && <span class="caption">{caption}</span>}
</div>

<style>
  .audio-player {
    /* margin: 15px 0; */
    max-width: 550px;
    margin: 0 auto;
    padding: 10px;
    width: 100%;
    background-color: #f5f5f5;
    border: 1px solid #ccc;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .audio-player audio {
    /* border-radius: 8px; */
    width: 100%;
  }

  .caption {
    /* font-style: italic; */
    /* margin: 8px 0 0; */
    background-color: transparent;
    z-index: 99;
    display: block;
    text-align: center;
    font-size: 0.9em;
    color: #666;
  }
</style>
