<script is:inline>
  ;(() => {
    const statsEl = document.querySelector("#stats")
    if (!statsEl) return

    // Encode path for GoatCounter — strip trailing slash except for root
    function getCounterPath() {
      let path = location.pathname

      // Prefer GoatCounter's own path if available
      if (window.goatcounter && typeof window.goatcounter.get_data === "function") {
        const data = window.goatcounter.get_data()
        if (data && data.p) path = data.p
      }

      // Normalize: remove trailing slash unless it's the root "/"
      if (path.length > 1 && path.endsWith("/")) {
        path = path.slice(0, -1)
      }

      if (path.startsWith("/")) {
        path = path.slice(1)
      }

      return encodeURIComponent(path)
    }

    // const url = "https://parrotspeech.goatcounter.com/counter/" + getCounterPath() + ".json"

    const r = new XMLHttpRequest()

    r.addEventListener("load", function () {
      if (this.status < 200 || this.status >= 300) {
        statsEl.innerText = "N/A"
        return
      }

      try {
        const payload = JSON.parse(this.responseText)
        const count = Number.parseInt(String(payload?.count ?? ""), 10)
        statsEl.innerText = Number.isFinite(count) ? String(count) : "0"
      } catch {
        statsEl.innerText = "N/A"
      }
    })

    r.addEventListener("error", () => {
      statsEl.innerText = "N/A"
    })

    r.open("GET", "https://parrotspeech.goatcounter.com/counter//.json")
    r.send()
  })()
</script>

