---
interface Props {
  label?: string
}

const { label = "" } = Astro.props
---

<div class="highlight-box">
  {label && <span class="label">{label}</span>}
  <div class="content">
    <slot />
  </div>
</div>

<style>
  .highlight-box {
    /* background-color: #ffffcc; */
    background-color: #ffffcc;
    color: #ff0000;
    border-left: 4px solid #ffcc00;
    /* border-left: 4px solid #ff0000; */
    padding: 20px;
    margin: 15px 0;
    border-radius: 8px;
  }

  .label {
    display: block;
    font-weight: bold;
    /* color: #663300; */
    font-weight: bold;
    font-size: 1.1em;
    margin-bottom: 8px;
  }

  .content {
    font-size: 1em;
    line-height: 1.6;
    /* color: #ffcc00; */
  }

  .content :global(strong) {
    color: #ff0000;
  }
</style>
